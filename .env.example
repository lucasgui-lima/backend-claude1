# ============================================================
# Variáveis de ambiente do backend
# Copie este arquivo para .env e preencha os valores.
# Em produção (Render/Fly/Docker), defina diretamente no painel.
# ============================================================

# --- Banco de dados (Supabase / PostgreSQL) ---
# OPÇÃO A: URL completa via Connection Pooler (RECOMENDADO — suporta IPv4)
#          Use a string fornecida no Supabase Dashboard > Database > Connection Pooler
DATABASE_URL=postgresql+psycopg2://postgres.tltuihtisnmmabojukal:S%40gui126307@aws-1-us-east-2.pooler.supabase.com:6543/postgres?sslmode=require

# OPÇÃO B: variáveis separadas (a senha é percent-encoded automaticamente)
# DB_USER=postgres.tltuihtisnmmabojukal
# DB_PASSWORD=S@gui126307
# DB_HOST=aws-1-us-east-2.pooler.supabase.com
# DB_PORT=6543
# DB_NAME=postgres

# --- Autenticação ---
# Gere com: openssl rand -hex 32
SECRET_KEY=troque-por-uma-chave-aleatoria-longa-em-producao
ACCESS_TOKEN_EXPIRE_MINUTES=720

# --- CORS ---
# Em produção, restrinja às URLs do seu app.
# Use "*" apenas em desenvolvimento; com "*" o backend desativa credentials.
CORS_ORIGINS=*

# --- Ambiente ---
# Defina como "prod" para forçar checagens de produção (ex.: SECRET_KEY obrigatória).
ENV=prod
